# --- Payment aggregator -- RECOMMENDED, use this first ---
# AGGREGATOR controls which processor both 'momo' and 'airtel' selections route
# through. Options: 'pesapal' | 'flutterwave' | 'none' (none = direct MTN/Airtel,
# see below). No frontend changes needed when switching between these.
AGGREGATOR=pesapal

# --- Pesapal ---
# 1. Sign up at https://www.pesapal.com (or grab instant demo keys from
#    https://developer.pesapal.com/api3-demo-keys.txt to test immediately).
# 2. Paste your Consumer Key/Secret below.
# 3. BACKEND_PUBLIC_URL must be your backend's real public URL (e.g. your Render
#    URL) -- Pesapal needs a public HTTPS endpoint for IPN notifications, so this
#    step will not work purely on localhost. Deploy first, then fill this in.
PESAPAL_CONSUMER_KEY=wG63GNy6snIKBidmXO6dNIVurWdlit3O
PESAPAL_CONSUMER_SECRET=GyyBANVyP9HmSzHs4zjBrxN+pmI=
PESAPAL_ENVIRONMENT=production
BACKEND_PUBLIC_URL=https://emboni-backend.onrender.com

# --- Flutterwave (alternative aggregator) ---
# Sign up at https://dashboard.flutterwave.com, get your TEST Secret Key from
# Settings > API. To use this instead of Pesapal, set AGGREGATOR=flutterwave above.
FLW_SECRET_KEY=

# --- MTN MoMo (Collections) -- direct integration, for later ---
# 1. Register at https://momodeveloper.mtn.co.rw (Rwanda) and subscribe to "Collections".
# 2. Copy your Primary Key into MOMO_SUBSCRIPTION_KEY below.
# 3. Run: node src/provision-momo-sandbox.js -- it prints MOMO_API_USER / MOMO_API_KEY for you.
MOMO_SUBSCRIPTION_KEY=
MOMO_API_USER=
MOMO_API_KEY=
MOMO_TARGET_ENVIRONMENT=sandbox
MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
# Only used in production (MTN calls this URL to confirm payments):
MOMO_CALLBACK_HOST=

# --- Airtel Money (Collections) -- direct integration, for later ---
# Register at https://developers.airtel.africa/developer, create an app, add "Collection APIs".
AIRTEL_CLIENT_ID=
AIRTEL_CLIENT_SECRET=
AIRTEL_BASE_URL=https://openapiuat.airtel.africa
AIRTEL_COUNTRY=RW
AIRTEL_CURRENCY=RWF

# --- Server ---
PORT=4000
# Your deployed frontend URL (e.g. https://imboni-car-rentals.vercel.app), so
# CORS only allows your own site to call this API. Use * while testing locally.
FRONTEND_ORIGIN=*
